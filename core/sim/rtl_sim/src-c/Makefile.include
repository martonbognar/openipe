OPENIPE         = ../framework
CC              = $(OPENIPE)/compiler.py
LD              = $(OPENIPE)/linker.py

CPU             = MSP430F149

INCLUDE         = -I$(OPENIPE)
CFLAGS          = -Wall -std=gnu99 -g -mmcu=msp430f149 -mhwmult=none -D__MSP430F149__ -Os
# to inspect the linker output if needed for troubleshooting: add "-Wl,-Map,output.map" to LDFLAGS
LDFLAGS         = -mmcu=msp430f149 -mhwmult=none -T pmem.x
